---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { posts, SUBSTACK_URL } from '../../data/posts';
import '../../styles/pages.css';
---

<BaseLayout
  title="Writing — Asymmetric"
  description="Asymmetric — Andreas Proesch's newsletter on AI, industry, and capital."
>

  <section class="phero section">
    <div class="wrap">
      <p class="eyebrow" data-reveal>Writing — Asymmetric</p>
      <h1 data-reveal data-delay="0.05">Asymmetric</h1>
      <p class="phero__intro" data-reveal data-delay="0.1">
        A newsletter on AI, industry, and capital.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:clamp(20px,3vw,36px);">
    <div class="wrap">
      <div class="blog-head" data-reveal>
        <div class="block-label" style="margin:0;">
          <span class="n">01 / Recent</span>
          <h2>Latest posts</h2>
        </div>
        <a class="btn btn--primary" href={SUBSTACK_URL} target="_blank" rel="noopener">Subscribe <span class="arr">→</span></a>
      </div>

      <div class="blog-list" data-reveal-group>
        {posts.map(post => (
          <a class="post-row" href={post.url} target="_blank" rel="noopener" data-reveal>
            <span class="date">{post.date}</span>
            <span class="ptitle">{post.title}</span>
            <span class="read">Read on Substack <span class="arr">→</span></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <section class="section contact-cta">
    <div class="wrap contact-cta__inner" data-reveal>
      <div>
        <p class="eyebrow">Subscribe</p>
        <h2 class="contact-cta__h">Read Asymmetric</h2>
        <p class="contact-cta__p">New essays on AI, industry, and capital — delivered when they're worth your time.</p>
      </div>
      <a class="btn btn--primary" href={SUBSTACK_URL} target="_blank" rel="noopener">Open Substack <span class="arr">→</span></a>
    </div>
  </section>

</BaseLayout>
