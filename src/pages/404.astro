---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages.css';
---

<BaseLayout
  title="Page not found"
  description="The page you're looking for doesn't exist or may have moved."
>
  <section class="phero section" style="text-align:center;">
    <div class="wrap">
      <p class="eyebrow" style="justify-content:center;">Error 404</p>
      <h1>Page not found</h1>
      <p class="phero__intro" style="margin-left:auto;margin-right:auto;">
        The page you're looking for doesn't exist or may have moved.
      </p>
      <div style="margin-top:32px;">
        <a class="btn btn--primary" href="/">Back to home <span class="arr">→</span></a>
      </div>
    </div>
  </section>
</BaseLayout>
