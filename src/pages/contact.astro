---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages.css';
---

<BaseLayout
  title="Contact"
  description="Get in touch with Andreas Proesch — speaking opportunities, advisory, startups and investment, or media. Also on LinkedIn, X, and Substack."
>

  <section class="phero section">
    <div class="wrap">
      <p class="eyebrow" data-reveal>Contact</p>
      <h1 data-reveal data-delay="0.05">Get in touch</h1>
      <p class="phero__intro" data-reveal data-delay="0.1">
        A question, a speaking opportunity, or something to discuss — get in touch, or find me on the
        platforms below.
      </p>
    </div>
  </section>

  <section class="section" style="padding-top:clamp(20px,3vw,40px);">
    <div class="wrap contact-grid">

      <!-- ============ FORM ============
           Wired for Web3Forms (free, routes submissions to your inbox; works on a
           static host — no backend). Get a free access key at https://web3forms.com
           (just enter your email) and replace YOUR_WEB3FORMS_KEY below. The key is
           not secret — it only permits submitting to your form. Spam protection:
           free zero-config hCaptcha + a honeypot. Until a real key is set, submit
           shows a friendly notice instead of failing. -->
      <form class="form" id="contactForm"
            action="https://api.web3forms.com/submit" method="POST" data-reveal>
        <!-- ◆ Replace with your free key from web3forms.com -->
        <input type="hidden" name="access_key" value="YOUR_WEB3FORMS_KEY" />
        <input type="hidden" name="subject" value="New enquiry from andreasproesch.com" />
        <input type="hidden" name="from_name" value="andreasproesch.com" />
        <!-- Honeypot: hidden from humans; bots that tick it are rejected -->
        <input type="checkbox" name="botcheck" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

        <div class="field">
          <label for="regarding">Regarding</label>
          <select id="regarding" name="regarding" required>
            <option value="" disabled selected>Select a topic…</option>
            <option>Speaking</option>
            <option>Advisory</option>
            <option>Startup or investment</option>
            <option>Media</option>
            <option>Something else</option>
          </select>
        </div>
        <div class="field">
          <label for="name">Name</label>
          <input type="text" id="name" name="name" placeholder="Your name" required autocomplete="name" />
        </div>
        <div class="field">
          <label for="email">Email</label>
          <input type="email" id="email" name="email" placeholder="you@company.com" required autocomplete="email" />
        </div>
        <div class="field">
          <label for="message">Message</label>
          <textarea id="message" name="message" placeholder="A few lines on what you have in mind…" required></textarea>
        </div>
        <!-- Free, zero-config hCaptcha (Web3Forms supplies the keys server-side) -->
        <div class="h-captcha" data-captcha="true" data-theme="dark"></div>

        <div style="display:flex;align-items:center;gap:18px;flex-wrap:wrap;">
          <button type="submit" class="btn btn--primary">Send message <span class="arr">→</span></button>
          <span class="form__status" id="formStatus" role="status" aria-live="polite"></span>
        </div>
        <p class="form__note">Messages are sent securely via Web3Forms and delivered to my inbox. Protected by hCaptcha — I'll never see or store your data anywhere else.</p>
      </form>

      <!-- ============ ELSEWHERE ============ -->
      <aside data-reveal data-delay="0.08">
        <div class="block-label" style="margin-bottom:18px;">
          <span class="n">Elsewhere</span>
        </div>
        <nav class="elsewhere" aria-label="Social profiles">
          <a href="https://linkedin.com/in/andreasproesch" target="_blank" rel="noopener">
            <span class="where"><b>LinkedIn</b><span>/in/andreasproesch</span></span>
            <span class="go">↗</span>
          </a>
          <a href="https://x.com/andreasproesch" target="_blank" rel="noopener">
            <span class="where"><b>X / Twitter</b><span>@andreasproesch</span></span>
            <span class="go">↗</span>
          </a>
          <a href="https://proesch.substack.com" target="_blank" rel="noopener">
            <span class="where"><b>Substack</b><span>Asymmetric</span></span>
            <span class="go">↗</span>
          </a>
          <a href="https://linktr.ee/andreasproesch" target="_blank" rel="noopener">
            <span class="where"><b>LinkTree</b><span>/andreasproesch</span></span>
            <span class="go">↗</span>
          </a>
        </nav>
      </aside>
    </div>
  </section>

  <!-- Renders the hCaptcha widget using Web3Forms' default keys -->
  <script src="https://web3forms.com/client/script.js" async defer is:inline></script>

  <script is:inline>
    (function () {
      var form = document.getElementById("contactForm");
      var statusEl = document.getElementById("formStatus");
      if (!form) return;

      function setStatus(msg, color) {
        statusEl.style.color = color || "var(--amber)";
        statusEl.textContent = msg;
      }

      form.addEventListener("submit", function (e) {
        e.preventDefault();

        // If the Web3Forms access key hasn't been configured yet, don't post to a
        // placeholder — show a clear notice so the form never silently fails.
        var keyField = form.querySelector('input[name="access_key"]');
        if (!keyField || keyField.value.indexOf("YOUR_WEB3FORMS_KEY") !== -1) {
          setStatus("Add your Web3Forms access key to enable sending.");
          return;
        }

        setStatus("Sending…", "var(--muted)");

        fetch(form.action, {
          method: "POST",
          body: new FormData(form),
          headers: { Accept: "application/json" }
        }).then(function (r) {
          return r.json().then(function (data) { return { ok: r.ok, data: data }; });
        }).then(function (res) {
          if (res.ok && res.data.success) {
            form.reset();
            setStatus("Thanks — I'll be in touch.");
          } else {
            // Surfaces Web3Forms messages such as "Please complete the captcha".
            setStatus((res.data && res.data.message) || "Something went wrong. Please try again.");
          }
          if (window.hcaptcha && typeof window.hcaptcha.reset === "function") {
            try { window.hcaptcha.reset(); } catch (err) { /* ignore */ }
          }
        }).catch(function () {
          setStatus("Network error. Please try again, or reach me via the links.");
        });
      });
    })();
  </script>

</BaseLayout>
