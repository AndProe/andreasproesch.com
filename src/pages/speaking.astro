---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages.css';

// Gallery is data-driven so captions (event + year) can be filled in one place.
// Set `event` and `year` on an item to label its photo; leave them off to show
// the "caption coming" placeholder.
const events = [
  { src: "speaking-event-1", ext: "jpg" },
  { src: "speaking-event-2", ext: "jpg" },
  { src: "speaking-event-3", ext: "jpg" },
  { src: "speaking-event-4", ext: "jpg" },
  { src: "speaking-event-6", ext: "jpg" },
  { src: "speaking-event-7", ext: "jpg" },
  { src: "speaking-event-8", ext: "jpg" },
  { src: "speaking-event-9", ext: "webp" },
] as { src: string; ext: string; event?: string; year?: string }[];
---

<BaseLayout
  title="Speaking"
  description="Andreas Proesch speaks on AI adoption, digital transformation, and tech trends at corporate conferences, board strategy meetings, and executive trainings across Europe and the Middle East."
  image="/images/speaking-main.jpg"
>

  <!-- ===================== HERO ===================== -->
  <section class="phero section">
    <div class="wrap">
      <p class="eyebrow" data-reveal>Speaking</p>
      <h1 data-reveal data-delay="0.05">Public Speaking</h1>
      <p class="phero__intro" data-reveal data-delay="0.1">
        I've seen tech and digital transformations accelerate and win, and I have seen them stall and fail.
        In the last few years, I've given presentations on AI transformations and digital adoption at corporate
        conferences, board strategy meetings, executive leadership trainings, and other events across Europe and
        the Middle East.
      </p>
    </div>
  </section>

  <!-- ===================== HERO IMAGE ===================== -->
  <section class="section" style="padding-top:0;">
    <div class="wrap speak-hero" data-reveal>
      <div class="framed">
        <span class="brk tl"></span><span class="brk br"></span>
        <div class="ph" style="aspect-ratio: 21/9;">
          <img src="/images/speaking-main.jpg" alt="Andreas Proesch speaking on stage" loading="lazy"
               style="width:100%;height:100%;object-fit:cover;"
               onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
          <span class="ph__label" style="display:none;"><b>speaking-main.jpg</b>On-stage hero · 21:9</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== TOPICS ===================== -->
  <section class="section" id="topics">
    <div class="wrap">
      <div class="sec-head" data-reveal>
        <span class="sec-head__num">01 / Topics</span>
        <h2>What I speak about</h2>
      </div>
      <div class="topics" data-reveal-group>
        <div class="card" data-reveal>
          <span class="num">/01</span>
          <h3>AI Adoption</h3>
          <p>Moving organizations from experimentation to production-grade systems that hold up under real operational load.</p>
        </div>
        <div class="card" data-reveal>
          <span class="num">/02</span>
          <h3>Digital Transformation</h3>
          <p>Leveraging technology to genuinely change how organizations operate — not just digitize what already exists.</p>
        </div>
        <div class="card" data-reveal>
          <span class="num">/03</span>
          <h3>Tech Trends</h3>
          <p>Emerging technologies with asymmetric disruption potential — where to pay attention, and where not to.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== GALLERY ===================== -->
  <section class="section" id="events">
    <div class="wrap">
      <div class="sec-head" data-reveal>
        <span class="sec-head__num">02 / From Past Events</span>
        <p>A selection from recent talks across Europe and the Middle East.</p>
      </div>
      <div class="gallery" data-reveal-group>
        {events.map((e, i) => (
          <figure data-reveal>
            <div class="ph" style="aspect-ratio:4/3;">
              <img src={`/images/${e.src}.${e.ext}`} alt={`On stage — event ${String(i + 1).padStart(2, "0")}`} loading="lazy" decoding="async"
                   onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
              <span class="ph__label" style="display:none;"><b>{e.src}.{e.ext}</b>Event {String(i + 1).padStart(2, "0")} · 4:3</span>
            </div>
            <figcaption>
              {e.event ? `${e.event} · ${e.year ?? ""}` : <span class="cap-soon">◆ Event name · Year</span>}
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- ===================== BOOKING ===================== -->
  <section class="section" id="invite">
    <div class="wrap">
      <div class="booking" data-reveal>
        <div>
          <p class="eyebrow">Invite me to speak</p>
          <h2>Bring this to your audience</h2>
          <p>Conferences, board sessions, and executive teams — available for keynotes, panels, and private briefings on AI transformation.</p>
          <div class="fmt">
            <span>Keynotes</span>
            <span>Conference Talks</span>
            <span>Workshops</span>
            <span>Panels</span>
            <span>Board Strategy Sessions</span>
          </div>
        </div>
        <div style="display:flex;justify-content:flex-end;">
          <a class="btn btn--primary" href="/contact">Get in touch <span class="arr">→</span></a>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
