---
import BaseLayout from '../layouts/BaseLayout.astro';
import '../styles/pages.css';
---

<BaseLayout
  title="About"
  description="Andreas Proesch works at the intersection of AI, industry, and capital — tech operator, advisor, and angel investor. Head of Programs, Applied AI Products at AI71."
>

  <!-- ===================== HERO + LEAD ===================== -->
  <section class="phero section">
    <div class="wrap">
      <p class="eyebrow" data-reveal>About</p>
      <h1 data-reveal data-delay="0.05">Andreas Proesch</h1>
    </div>
  </section>

  <section class="section--tight section" style="padding-top:0;">
    <div class="wrap about-lead">
      <div class="prose" data-reveal>
        <p>I work at the intersection of AI, industry, and capital — as a tech operator, advisor, and early-stage investor.</p>
        <p>I'm trained as a robotics engineer, but most of my career has been spent putting advanced technology to practical use. Over the past decade, I've worked with executive teams, investors, operators, and technologists across energy, manufacturing, commodities, and data-intensive industries.</p>
        <p>Today, I'm <span class="amber">Head of Programs, Applied AI Products at AI71</span> in Abu Dhabi, where I focus on moving organizations from AI experimentation to AI-first operating models. My work sits where AI meets physical assets, regulation, legacy systems, and scale — particularly in industrial and sovereign contexts.</p>
        <p>A recurring theme in my work is what I call the <span class="amber">Supply Chains of Intelligence</span>: how energy, compute, data, models, software, and decision-making fit together — and where value, risk, and leverage actually sit.</p>
        <p>Alongside my advisory work, I'm an active angel investor in early-stage companies building foundational AI, data, and industrial software.</p>
        <p>I speak and advise on AI, industrial transformation, and technology strategy.</p>
      </div>

      <aside class="about-portrait" data-reveal data-delay="0.1">
        <div class="framed">
          <span class="brk tl"></span><span class="brk br"></span>
          <div class="ph" style="aspect-ratio: 4/5;">
            <img src="/images/andreas-proesch.jpg" alt="Andreas Proesch" loading="lazy"
                 style="width:100%;height:100%;object-fit:cover;"
                 onerror="this.style.display='none';this.nextElementSibling.style.display='flex';" />
            <span class="ph__label" style="display:none;"><b>andreas-proesch.jpg</b>Portrait · 4:5</span>
          </div>
        </div>
      </aside>
    </div>
  </section>

  <!-- ===================== WHO I WORK WITH ===================== -->
  <section class="section" id="work-with">
    <div class="wrap">
      <div class="sec-head" data-reveal>
        <span class="sec-head__num">01 / Who I Work With</span>
        <h2>Across the value chain</h2>
      </div>
      <div class="grid6" data-reveal-group>
        <div class="cell" data-reveal>
          <span class="idx">001</span>
          <h3>PE &amp; VC Funds</h3>
          <p>AI strategy, diligence, value-creation, and long-term platform thinking.</p>
        </div>
        <div class="cell" data-reveal>
          <span class="idx">002</span>
          <h3>Governments &amp; Ministries</h3>
          <p>Sovereign AI, industrial policy, and large-scale digital transformation.</p>
        </div>
        <div class="cell" data-reveal>
          <span class="idx">003</span>
          <h3>Large-Scale Enterprises</h3>
          <p>Moving leadership teams from pilots to production-grade AI.</p>
        </div>
        <div class="cell" data-reveal>
          <span class="idx">004</span>
          <h3>Industrial Conglomerates</h3>
          <p>AI at the intersection of operations, safety, and physical infrastructure.</p>
        </div>
        <div class="cell" data-reveal>
          <span class="idx">005</span>
          <h3>Boards &amp; Management</h3>
          <p>Strategic perspective on AI risk, opportunity, and organizational readiness.</p>
        </div>
        <div class="cell" data-reveal>
          <span class="idx">006</span>
          <h3>Startup Founders</h3>
          <p>Partnering early on product direction, technical strategy, and go-to-market.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== EXPERIENCE ===================== -->
  <section class="section" id="experience">
    <div class="wrap">
      <div class="sec-head" data-reveal>
        <span class="sec-head__num">02 / Experience</span>
        <h2>Professional background</h2>
      </div>
      <ol class="timeline" data-reveal-group>
        <li data-reveal>
          <span class="when">Present</span>
          <div class="role"><h3>Head of Programs, Applied AI Products</h3><span class="org">AI71</span></div>
          <span class="tag">Sovereign Agentic AI</span>
        </li>
        <li data-reveal>
          <span class="when">Prev</span>
          <div class="role"><h3>Vice President &amp; Head of Aker AI Unit</h3><span class="org">Cognite &amp; Aker ASA</span></div>
          <span class="tag">B2B SaaS · Industrial AI &amp; DataOps</span>
        </li>
        <li data-reveal>
          <span class="when">Prev</span>
          <div class="role"><h3>Snr. Finance Professional, Digital Investments</h3><span class="org">AkerBP</span></div>
          <span class="tag">Energy</span>
        </li>
        <li data-reveal>
          <span class="when">Prev</span>
          <div class="role"><h3>Project Leader</h3><span class="org">Boston Consulting Group</span></div>
          <span class="tag">Management Consulting</span>
        </li>
      </ol>
    </div>
  </section>

  <!-- ===================== EDUCATION ===================== -->
  <section class="section section--tight" id="education">
    <div class="wrap">
      <div class="block-label" data-reveal>
        <span class="n">03 / Education</span>
        <h2>Foundations</h2>
      </div>
      <div class="edu" data-reveal-group>
        <div class="card" data-reveal>
          <span class="idx">/01</span>
          <div class="deg">MBA</div>
          <div class="school">INSEAD</div>
        </div>
        <div class="card" data-reveal>
          <span class="idx">/02</span>
          <div class="deg">MEng, Mechanical Engineering</div>
          <div class="school">Imperial College London</div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===================== CONTACT CTA ===================== -->
  <section class="section contact-cta">
    <div class="wrap contact-cta__inner" data-reveal>
      <div>
        <p class="eyebrow">Contact</p>
        <h2 class="contact-cta__h">Get in touch</h2>
        <p class="contact-cta__p">For advisory, a board perspective, or early-stage companies.</p>
      </div>
      <a class="btn btn--primary" href="/contact">Get in touch <span class="arr">→</span></a>
    </div>
  </section>

</BaseLayout>
