---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Writing' },
  { href: '/speaking', label: 'Speaking' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/books', label: 'Reading' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string): boolean {
  return currentPath === href || currentPath === href + '/' || currentPath.startsWith(href + '/');
}

const isHome = currentPath === '/';
---

<header class="nav">
  <div class="wrap nav__inner">
    <a href="/" class="brand" {...(isHome ? { 'aria-current': 'page' } : {})}>Proesch<span class="dot">.</span></a>

    <nav class="nav__links" aria-label="Primary">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={[{ active: isActive(link.href) }]}
          {...(isActive(link.href) ? { 'aria-current': 'page' } : {})}
        >{link.label}</a>
      ))}
    </nav>

    <div class="nav__right">
      <span class="status" title="Andreas’ local time">
        <span class="status__dot"></span>
        <span class="status__txt" id="statusTxt">Abu Dhabi · UTC+4</span>
      </span>
      <button class="nav__burger" id="burger" aria-label="Menu" aria-expanded="false">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <div class="nav__mobile" id="navMobile">
    {navLinks.map((link, i) => (
      <a
        href={link.href}
        class:list={[{ active: isActive(link.href) }]}
        {...(isActive(link.href) ? { 'aria-current': 'page' } : {})}
      >{link.label}<span class="i">/{String(i + 1).padStart(2, '0')}</span></a>
    ))}
  </div>
</header>
