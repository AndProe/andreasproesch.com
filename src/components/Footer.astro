---
const currentYear = new Date().getFullYear();

const footerLinks = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Writing' },
  { href: '/speaking', label: 'Speaking' },
  { href: '/portfolio', label: 'Portfolio' },
  { href: '/books', label: 'Reading' },
  { href: '/contact', label: 'Contact' },
];
---

<footer class="footer">
  <div class="wrap footer__inner">
    <div class="footer__brand">
      <div class="wm">Proesch<span class="dot">.</span></div>
      <div class="tag">Tech Operator · Advisor · Angel Investor</div>
    </div>
    <nav class="footer__links" aria-label="Footer">
      {footerLinks.map(link => <a href={link.href}>{link.label}</a>)}
    </nav>
  </div>
  <div class="footer__base">
    <div class="wrap">
      <span class="mono">© {currentYear} Andreas Proesch · Abu Dhabi · UTC+4</span>
    </div>
  </div>
</footer>
